<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- Driver Rule: Only see own trips -->
        <record id="rule_transitops_trip_driver" model="ir.rule">
            <field name="name">TransitOps Trip: Driver sees own</field>
            <field name="model_id" ref="model_transitops_trip"/>
            <field name="domain_force">[('driver_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('transitops_core.group_driver'))]"/>
        </record>

        <!-- Manager Rule: See all trips -->
        <record id="rule_transitops_trip_manager" model="ir.rule">
            <field name="name">TransitOps Trip: Managers see all</field>
            <field name="model_id" ref="model_transitops_trip"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('transitops_core.group_fleet_manager')), (4, ref('transitops_core.group_financial_analyst')), (4, ref('transitops_core.group_safety_officer'))]"/>
        </record>

    </data>
</odoo>
