<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_transitops_driver_tree" model="ir.ui.view">
        <field name="name">transitops.driver.tree</field>
        <field name="model">transitops.driver</field>
        <field name="arch" type="xml">
            <tree string="Drivers">
                <field name="name"/>
                <field name="license_number"/>
                <field name="license_category"/>
                <field name="license_expiry"/>
                <field name="safety_score"/>
                <field name="status"/>
            </tree>
        </field>
    </record>

    <record id="view_transitops_driver_form" model="ir.ui.view">
        <field name="name">transitops.driver.form</field>
        <field name="model">transitops.driver</field>
        <field name="arch" type="xml">
            <form string="Driver">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="contact_number"/>
                            <field name="status"/>
                        </group>
                        <group>
                            <field name="license_number"/>
                            <field name="license_category"/>
                            <field name="license_expiry"/>
                            <field name="safety_score"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_transitops_driver_search" model="ir.ui.view">
        <field name="name">transitops.driver.search</field>
        <field name="model">transitops.driver</field>
        <field name="arch" type="xml">
            <search string="Drivers">
                <field name="name"/>
                <field name="license_number"/>
                <filter string="Available" name="available" domain="[('status', '=', 'available')]"/>
                <filter string="On Trip" name="on_trip" domain="[('status', '=', 'on_trip')]"/>
                <filter string="Off Duty" name="off_duty" domain="[('status', '=', 'off_duty')]"/>
                <filter string="Suspended" name="suspended" domain="[('status', '=', 'suspended')]"/>
            </search>
        </field>
    </record>
</odoo>
