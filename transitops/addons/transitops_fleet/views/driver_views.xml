<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- View: Form -->
    <record id="view_transitops_driver_form" model="ir.ui.view">
        <field name="name">transitops.driver.form</field>
        <field name="model">transitops.driver</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="status" widget="statusbar" statusbar_visible="available,on_trip,off_duty,suspended"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(transitops_fleet.action_transitops_trip)d" type="action" class="oe_stat_button" icon="fa-road" context="{'search_default_driver_id': id, 'default_driver_id': id}">
                            <div class="o_stat_info">
                                <field name="trip_count" class="o_stat_value"/>
                                <span class="o_stat_text">Trips</span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Driver Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="license_number"/>
                            <field name="license_category"/>
                            <field name="license_expiry"/>
                            <field name="region"/>
                        </group>
                        <group>
                            <field name="contact_number"/>
                            <field name="safety_score"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- View: Tree -->
    <record id="view_transitops_driver_tree" model="ir.ui.view">
        <field name="name">transitops.driver.tree</field>
        <field name="model">transitops.driver</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="license_number"/>
                <field name="license_expiry"/>
                <field name="region"/>
                <field name="status" decoration-success="status=='available'" decoration-info="status=='on_trip'" decoration-warning="status=='off_duty'" decoration-danger="status=='suspended'" widget="badge"/>
            </tree>
        </field>
    </record>

    <!-- View: Search -->
    <record id="view_transitops_driver_search" model="ir.ui.view">
        <field name="name">transitops.driver.search</field>
        <field name="model">transitops.driver</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="license_number"/>
                <field name="region"/>
                <filter string="North Region" name="filter_region_north" domain="[('region', '=', 'north')]"/>
                <filter string="South Region" name="filter_region_south" domain="[('region', '=', 'south')]"/>
                <filter string="East Region" name="filter_region_east" domain="[('region', '=', 'east')]"/>
                <filter string="West Region" name="filter_region_west" domain="[('region', '=', 'west')]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_by_status" context="{'group_by':'status'}"/>
                    <filter string="Region" name="group_by_region" context="{'group_by':'region'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_transitops_driver" model="ir.actions.act_window">
        <field name="name">Drivers</field>
        <field name="res_model">transitops.driver</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Menus -->
    <menuitem id="menu_transitops_driver" name="Drivers" parent="transitops_core.menu_transitops_fleet" action="action_transitops_driver" sequence="20"/>

</odoo>
