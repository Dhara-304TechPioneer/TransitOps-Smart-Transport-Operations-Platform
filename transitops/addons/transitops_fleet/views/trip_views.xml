<?xml version="1.0" encoding="utf-8"?>
<odoo>
 <record id="view_transitops_trip_list" model="ir.ui.view"><field name="name">transitops.trip.list</field><field name="model">transitops.trip</field><field name="arch" type="xml"><tree decoration-info="state == 'dispatched'" decoration-success="state == 'completed'" decoration-muted="state == 'cancelled'"><field name="source"/><field name="destination"/><field name="vehicle_id"/><field name="driver_id"/><field name="cargo_weight_kg"/><field name="state" widget="badge"/></tree></field></record>
 <record id="view_transitops_trip_form" model="ir.ui.view"><field name="name">transitops.trip.form</field><field name="model">transitops.trip</field><field name="arch" type="xml"><form><header><button name="action_dispatch" type="object" string="Dispatch" class="btn-primary" invisible="state != 'draft'" groups="transitops_core.group_fleet_manager,transitops_core.group_driver"/><button name="action_complete" type="object" string="Complete" class="btn-success" invisible="state != 'dispatched'" groups="transitops_core.group_fleet_manager,transitops_core.group_driver"/><button name="action_cancel" type="object" string="Cancel" invisible="state not in ('draft', 'dispatched')" groups="transitops_core.group_fleet_manager,transitops_core.group_driver"/><field name="state" widget="statusbar" statusbar_visible="draft,dispatched,completed,cancelled"/></header><sheet><group><group><field name="source" readonly="state != 'draft'"/><field name="destination" readonly="state != 'draft'"/><field name="vehicle_id" domain="[('status','=','available')]" readonly="state != 'draft'"/><field name="driver_id" domain="[('status','=','available'), ('license_expiry','&gt;=', context_today())]" readonly="state != 'draft'"/></group><group><field name="cargo_weight_kg" readonly="state != 'draft'"/><field name="planned_distance_km" readonly="state != 'draft'"/><field name="fuel_consumed" readonly="state != 'dispatched'"/><field name="final_odometer" readonly="state != 'dispatched'"/><field name="revenue" readonly="state != 'dispatched'"/><field name="fuel_efficiency" readonly="1"/><field name="currency_id" invisible="1"/></group></group></sheet></form></field></record>
 <record id="action_transitops_trip" model="ir.actions.act_window"><field name="name">Trips</field><field name="res_model">transitops.trip</field><field name="view_mode">tree,form</field></record>
 <menuitem id="menu_transitops_trips" name="Trips" parent="transitops_core.menu_transitops_root" action="action_transitops_trip" sequence="40"/>
</odoo>
