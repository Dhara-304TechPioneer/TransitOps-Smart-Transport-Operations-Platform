<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_transitops_trip_tree" model="ir.ui.view">
        <field name="name">transitops.trip.tree</field>
        <field name="model">transitops.trip</field>
        <field name="arch" type="xml">
            <tree string="Trips">
                <field name="source"/>
                <field name="destination"/>
                <field name="vehicle_id"/>
                <field name="driver_id"/>
                <field name="cargo_weight_kg"/>
                <field name="planned_distance_km"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_transitops_trip_form" model="ir.ui.view">
        <field name="name">transitops.trip.form</field>
        <field name="model">transitops.trip</field>
        <field name="arch" type="xml">
            <form string="Trip">
                <header>
                    <button name="action_dispatch" string="Dispatch" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_complete" string="Complete" type="object" class="btn-primary" invisible="state != 'dispatched'"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state not in ('draft', 'dispatched')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,dispatched,completed,cancelled"/>
                </header>
                <sheet>
                    <group string="Trip Information">
                        <group>
                            <field name="source"/>
                            <field name="destination"/>
                        </group>
                        <group>
                            <field name="vehicle_id" domain="[('status', '=', 'available')]"/>
                            <field name="driver_id" domain="[('status', '=', 'available')]"/>
                        </group>
                    </group>
                    <group string="Trip Details">
                        <group>
                            <field name="cargo_weight_kg"/>
                            <field name="planned_distance_km"/>
                        </group>
                        <group>
                            <field name="fuel_consumed"/>
                            <field name="final_odometer"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_transitops_trip_search" model="ir.ui.view">
        <field name="name">transitops.trip.search</field>
        <field name="model">transitops.trip</field>
        <field name="arch" type="xml">
            <search string="Trips">
                <field name="source"/>
                <field name="destination"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Dispatched" name="dispatched" domain="[('state', '=', 'dispatched')]"/>
                <filter string="Completed" name="completed" domain="[('state', '=', 'completed')]"/>
                <filter string="Cancelled" name="cancelled" domain="[('state', '=', 'cancelled')]"/>
            </search>
        </field>
    </record>
</odoo>
