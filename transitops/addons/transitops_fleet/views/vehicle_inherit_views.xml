<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit Vehicle Form to add Trip Smart Button -->
    <record id="view_vehicle_form_inherit_fleet" model="ir.ui.view">
        <field name="name">transitops.vehicle.form.inherit.fleet</field>
        <field name="model">transitops.vehicle</field>
        <field name="inherit_id" ref="transitops_core.view_transitops_vehicle_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="%(transitops_fleet.action_transitops_trip)d" type="action" class="oe_stat_button" icon="fa-road" context="{'search_default_vehicle_id': id, 'default_vehicle_id': id}">
                    <div class="o_stat_info">
                        <field name="trip_count" class="o_stat_value"/>
                        <span class="o_stat_text">Trips</span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
