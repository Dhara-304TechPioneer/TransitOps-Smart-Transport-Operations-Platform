<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="ir_cron_check_license_expiry" model="ir.cron">
        <field name="name">Check Driver License Expiry</field>
        <field name="model_id" ref="transitops_fleet.model_transitops_driver"/>
        <field name="state">code</field>
        <field name="code">model._cron_check_license_expiry()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="doall" eval="False"/>
        <field name="active" eval="True"/>
    </record>
</odoo>
