<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Maintenance View: Form -->
    <record id="view_transitops_maintenance_form" model="ir.ui.view">
        <field name="name">transitops.maintenance.form</field>
        <field name="model">transitops.maintenance</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_close" string="Close Maintenance" type="object" class="oe_highlight" invisible="active == False"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="vehicle_id"/>
                            <field name="date"/>
                        </group>
                        <group>
                            <field name="cost"/>
                            <field name="active" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Maintenance View: Tree -->
    <record id="view_transitops_maintenance_tree" model="ir.ui.view">
        <field name="name">transitops.maintenance.tree</field>
        <field name="model">transitops.maintenance</field>
        <field name="arch" type="xml">
            <tree decoration-muted="active==False" decoration-danger="active==True">
                <field name="vehicle_id"/>
                <field name="date"/>
                <field name="description"/>
                <field name="cost"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <!-- Maintenance Action -->
    <record id="action_transitops_maintenance" model="ir.actions.act_window">
        <field name="name">Maintenance</field>
        <field name="res_model">transitops.maintenance</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Menus -->
    <menuitem id="menu_transitops_ops" name="Operations" parent="transitops_core.menu_transitops_root" sequence="30"/>
    <menuitem id="menu_transitops_maintenance" name="Maintenance" parent="menu_transitops_ops" action="action_transitops_maintenance" sequence="10"/>

</odoo>
