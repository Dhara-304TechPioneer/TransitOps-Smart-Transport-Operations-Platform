<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Fuel Log View: Tree -->
    <record id="view_transitops_fuel_log_tree" model="ir.ui.view">
        <field name="name">transitops.fuel_log.tree</field>
        <field name="model">transitops.fuel_log</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="vehicle_id"/>
                <field name="date"/>
                <field name="liters"/>
                <field name="cost"/>
            </tree>
        </field>
    </record>

    <!-- Fuel Log Action -->
    <record id="action_transitops_fuel_log" model="ir.actions.act_window">
        <field name="name">Fuel Logs</field>
        <field name="res_model">transitops.fuel_log</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Expense View: Tree -->
    <record id="view_transitops_expense_tree" model="ir.ui.view">
        <field name="name">transitops.expense.tree</field>
        <field name="model">transitops.expense</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="vehicle_id"/>
                <field name="date"/>
                <field name="category"/>
                <field name="amount"/>
            </tree>
        </field>
    </record>

    <!-- Expense Action -->
    <record id="action_transitops_expense" model="ir.actions.act_window">
        <field name="name">Expenses</field>
        <field name="res_model">transitops.expense</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Menus -->
    <menuitem id="menu_transitops_financials" name="Financials" parent="transitops_core.menu_transitops_root" sequence="40"/>
    <menuitem id="menu_transitops_fuel_log" name="Fuel Logs" parent="menu_transitops_financials" action="action_transitops_fuel_log" sequence="10"/>
    <menuitem id="menu_transitops_expense" name="Expenses" parent="menu_transitops_financials" action="action_transitops_expense" sequence="20"/>

</odoo>
