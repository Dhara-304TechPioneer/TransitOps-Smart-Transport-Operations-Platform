<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- View: Pivot for ROI Analysis -->
    <record id="view_transitops_vehicle_pivot" model="ir.ui.view">
        <field name="name">transitops.vehicle.pivot</field>
        <field name="model">transitops.vehicle</field>
        <field name="arch" type="xml">
            <pivot string="Vehicle ROI Analysis" disable_linking="True">
                <field name="name" type="row"/>
                <field name="revenue" type="measure"/>
                <field name="operational_cost" type="measure"/>
                <field name="roi_percentage" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- View: Graph for Operational Cost -->
    <record id="view_transitops_vehicle_graph" model="ir.ui.view">
        <field name="name">transitops.vehicle.graph</field>
        <field name="model">transitops.vehicle</field>
        <field name="arch" type="xml">
            <graph string="Operational Costs" type="bar">
                <field name="name"/>
                <field name="operational_cost" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- Action -->
    <record id="action_transitops_reports" model="ir.actions.act_window">
        <field name="name">Vehicle ROI Reports</field>
        <field name="res_model">transitops.vehicle</field>
        <field name="view_mode">pivot,graph,tree,form</field>
    </record>

    <menuitem id="menu_transitops_reports" name="Reports" parent="menu_transitops_financials" action="action_transitops_reports" sequence="30"/>
</odoo>
